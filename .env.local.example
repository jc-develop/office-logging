# Required by the app (public, safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Required by the app (secret — never commit to git)
# Get your service_role key from Supabase Dashboard → Settings → API
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Required in production (secret — never commit to git)
# Generate a 32-byte hex key for AES-256-GCM name encryption:
#   openssl rand -hex 32
NAME_ENCRYPTION_KEY=

# Pepper for SHA-256 name hash lookups (any random string)
NAME_HASH_PEPPER=

